{
  "name": "@inflowpayai/inflow",
  "version": "0.5.0",
  "type": "module",
  "license": "MIT",
  "description": "InFlow — agentic MPP / x402 payments from your machine.",
  "homepage": "https://github.com/inflowpayai/inflow-cli#readme",
  "bin": {
    "inflow": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "clean": "rm -rf dist .turbo"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inflowpayai/inflow-cli.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/inflowpayai/inflow-cli/issues"
  },
  "dependencies": {
    "@inflowpayai/inflow-core": "workspace:^",
    "@inflowpayai/x402": "^0.7.0",
    "@inflowpayai/x402-buyer": "^0.6.2",
    "@x402/core": "^2.12.0",
    "incur": "^0.4.5",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "update-notifier": "^7.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "@types/update-notifier": "^6.0.8",
    "@vitest/coverage-v8": "^2.1.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0"
  },
  "keywords": [
    "onboarding",
    "payments",
    "x402",
    "mpp",
    "agentic",
    "inflow",
    "wallet"
  ]
}
