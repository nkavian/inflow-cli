{
  "name": "@inflowpayai/inflow-core",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Typed HTTP client and resource interfaces for InFlow. Workspace-internal.",
  "homepage": "https://github.com/inflowpayai/inflow-cli#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.examples.json",
    "clean": "rm -rf dist .turbo"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inflowpayai/inflow-cli.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/inflowpayai/inflow-cli/issues"
  },
  "dependencies": {
    "conf": "^13.1.0",
    "strip-ansi": "^7.2.0"
  },
  "peerDependencies": {
    "@inflowpayai/x402": "^0.7.0",
    "@inflowpayai/x402-buyer": "^0.6.2",
    "@x402/core": "^2.12.0"
  },
  "devDependencies": {
    "@inflowpayai/x402": "^0.7.0",
    "@inflowpayai/x402-buyer": "^0.6.2",
    "@x402/core": "^2.12.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0"
  }
}
